{
  "layer": "bottom",
  "position": "top",
  "height": 30,
  "margin-top": 10,
  "margin-left": 12,
  "margin-right": 12,
  "spacing": 12,

  "modules-left": [ "cpu", "memory","hyprland/window"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": ["custom/media","tray","custom/keyboard","pulseaudio", "network", "clock", "custom/notifications"],

  "hyprland/workspaces": {
    "format": "{name}",
    "on-click": "activate"
  },

  "clock": {
    "format": "{:%a %d %b %H:%M}",
    "tooltip-format": false
  },

  "pulseaudio": {
    "format": "  {volume}%",
    "format-muted": "  muted",
    "on-click": "pavucontrol"
  },

  "network": {
    "format-wifi": "  {signalStrength}%",
    "format-ethernet": "󰈀  wired",
    "format-disconnected": "󰖪  offline",
    "tooltip-format": "{ifname}\n{ipaddr}"
  },

  "cpu": { "format": "  {usage}%" },
  "memory": { "format": "󰍛  {used:0.1f}G" },

  "tray": {
    "spacing": 10,
    "icon-size": 20,
    "icons": {
       "vesktop": ".local/share/icons/hicolor/64x64/apps/discord.svg",
     }
  },

  "custom/media": {
    "interval": 1,
    "return-type": "json",
    "exec": "~/.config/waybar/modules/media.sh",
    "escape": true
  },

  "custom/keyboard": {
    "exec": "~/.config/waybar/modules/keyboard-layout.sh",
    "interval": 1,
    "tooltip": false
  },

  "custom/notifications": {
    "exec": "swaync-client -c",
    "on-click": "swaync-client -t",
    "interval": 5
  }
}