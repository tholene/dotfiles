{
  "layer": "bottom",
  "position": "top",
  "height": 36,
  "margin-top": 12,
  "margin-left": 12,
  "margin-right": 12,
  "spacing": 12,

  "reload_style_on_change": true,

  "modules-left": [ "cpu", "memory", "network#speed"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": ["mpris", "tray","custom/keyboard", "clock", "custom/notifications"],

  "hyprland/workspaces": {
    "format": "{name} {icon}",
    "on-click": "activate",
    "format-icons": {
      "1": "ï„ ",
      "2": "ï‰¨",
      "3": "ï„،",
      "4": "ï†¼",
      "5": "ïپµ",
      "urgent": "ïپھ",
      "active": "ï†’",
      "default": "ï„‘"
    },
    "sort-by-number": true
  },

  "clock": {
    "format": "{:%a %d %b %H:%M}",
    "tooltip-format": false
  },

  "pulseaudio": {
    "format": "ï€¨  {volume}%",
    "format-muted": "ï‘¦  muted"
  },

  "network#speed": {
    "interval": 1,
    "format": "{ifname}",
    "format-wifi": "ï„؛ {bandwidthDownBytes} ï„¹ {bandwidthUpBytes} ",
    "format-ethernet": "ï„؛ {bandwidthDownBytes} ï„¹ {bandwidthUpBytes} ",
    "format-disconnected": "َ°Œ™",
    "tooltip-format": "{ipaddr}",
    "format-linked": "َ°ˆپ {ifname} (No IP)",
    "tooltip-format-ethernet": "َ°ˆ€ {ifname}\n{ipaddr}",
    "tooltip-format-disconnected": "َ°Œ™ Disconnected",
    "max-length": 30
  },

  "cpu": { "format": "ï’¼  {usage}%" },
  "memory": { "format": "َ°چ›  {used:0.1f}G" },

  "tray": {
    "spacing": 10,
    "icon-size": 20
  },

  "mpris": {
    "format": "{dynamic} {player_icon} ",
    "format-paused": "{status_icon} ",
    "player-icons": {
      "default": "\uf28b",
      "spotify": "ï†¼",
      "chromium": "ï‰¨"
    },
    "status-icons": {
      "paused": "\uf144"
    },
    "dynamic-order": [
      "title",
      "artist",
      "album"
    ],
    "on-click": "hyprctl dispatch exec [float] hyprmixer",
    "max-length": 1000,
    "interval": 1
  },

  "custom/media": {
    "interval": 1,
    "return-type": "json",
    "exec": "~/.config/waybar/modules/media.sh",
    "escape": true
  },

  "custom/keyboard": {
    "exec": "~/.config/waybar/modules/keyboard-layout.sh",
    "interval": 1,
    "tooltip": false
  },

  "custom/notifications": {
    "tooltip": true,
    "format": "{icon} {0}",
    "format-icons": {
      "notification": "َ±…«",
      "none": "َ°‚œ",
      "dnd-notification": "َ°‚ ",
      "dnd-none": "َ°ھ“",
      "inhibited-notification": "َ°‚›",
      "inhibited-none": "َ°ھ‘",
      "dnd-inhibited-notification": "َ°‚›",
      "dnd-inhibited-none": "َ°ھ‘"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  }
}